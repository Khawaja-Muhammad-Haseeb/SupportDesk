# Base URL the frontend uses for API calls.
# Left as a relative path so the Vite dev server proxy forwards it to the
# backend (configured via BACKEND_URL). Override only if you call the backend
# directly without the proxy, e.g. VITE_API_BASE_URL=http://localhost:8000/api
VITE_API_BASE_URL=/api

# Target the Vite dev server proxies "/api" to. Inside Docker Compose this is
# set to http://backend:8000 so the frontend container reaches the backend by
# service name.
BACKEND_URL=http://localhost:8000
